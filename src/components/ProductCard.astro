---
interface Props {
  name: string;
  tagline: string;
  description: string;
  price: string;
  weight: string;
  badge?: string;
  image: string;
  slug: string;
}

const { name, tagline, description, price, weight, badge, image, slug } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<a href={`${base}products/${slug}/`} class="group block bg-white rounded-2xl border border-honey-200/60 overflow-hidden shadow-sm hover:shadow-lg hover:shadow-honey-500/10 hover:-translate-y-1 transition-all duration-300">
  <!-- Image -->
  <div class="relative aspect-square bg-honey-100 overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-honey-200/60 to-honey-300/40 flex items-center justify-center">
      <span class="text-7xl opacity-60">🍯</span>
    </div>
    {badge && (
      <span class="absolute top-3 left-3 text-xs font-semibold px-3 py-1 rounded-full bg-honey-700 text-white shadow-sm">
        {badge}
      </span>
    )}
  </div>

  <!-- Info -->
  <div class="p-5">
    <h3 class="font-serif text-lg font-bold text-honey-900 group-hover:text-honey-800 transition-colors">
      {name}
    </h3>
    <p class="text-sm font-medium text-honey-800 mt-1">{tagline}</p>
    <p class="text-sm text-honey-800 mt-2 leading-relaxed line-clamp-2">{description}</p>
    <div class="mt-4 flex items-center justify-between">
      <div>
        <span class="text-lg font-bold text-honey-900">{price}</span>
        <span class="text-sm text-honey-700 ml-1">/ {weight}</span>
      </div>
      <span class="text-sm font-semibold text-honey-800 group-hover:translate-x-1 transition-transform duration-200">
        View →
      </span>
    </div>
  </div>
</a>
