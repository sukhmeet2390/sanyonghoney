---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="bg-white border border-honey-200/60 rounded-xl p-6 hover:border-honey-400/40 hover:shadow-sm transition-all">
  <span class="text-3xl">{icon}</span>
  <h3 class="text-base font-serif font-semibold text-honey-900 mt-3">{title}</h3>
  <p class="text-sm text-honey-800 mt-2 leading-relaxed">{description}</p>
</div>
